{
  "name": "japanese-learning-monorepo",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "preview:web": "pnpm --filter @japanese-learning/web preview",
    "serve:web": "pnpm --filter @japanese-learning/web serve",
    "release:web": "pnpm --filter @japanese-learning/web release",
    "eas:build:ios": "pnpm --filter mobile run eas:build:ios",
    "eas:build:android": "pnpm --filter mobile run eas:build:android",
    "eas:build:preview": "pnpm --filter mobile run eas:build:preview",
    "mobile:doctor": "pnpm --filter mobile run doctor"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.3"
}
