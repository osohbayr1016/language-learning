{
  "name": "chinese-learning-monorepo",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "preview:web": "pnpm --filter @chinese-app/web preview",
    "serve:web": "pnpm --filter @chinese-app/web serve",
    "release:web": "pnpm --filter @chinese-app/web release"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.3"
}
