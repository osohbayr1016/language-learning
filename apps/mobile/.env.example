# Copy values into `.env.local` so Metro picks them up (do not commit real secrets).

# Align local Expo web/native with deployed app data (recommended default).
EXPO_PUBLIC_API_URL=https://chinese-learning-api.osohoo691016.workers.dev

# Production SPA URL (HTTPS) — Play/App Store privacy & account deletion links.
EXPO_PUBLIC_SITE_URL=https://your-production-web-host.example

# Legal copy placeholders — replace before store submission (mirrored in app.config extra).
EXPO_PUBLIC_LEGAL_PUBLISHER_NAME=[Your company]
EXPO_PUBLIC_LEGAL_SUPPORT_EMAIL=support@yourdomain.mn
EXPO_PUBLIC_LEGAL_PRIVACY_EMAIL=privacy@yourdomain.mn
EXPO_PUBLIC_LEGAL_CONTACT_PHONE=[phone]
EXPO_PUBLIC_LEGAL_WEBSITE_URL=https://yourdomain.mn
EXPO_PUBLIC_LEGAL_APP_DISPLAY_NAME=Бөөндөө Study / Buunduu Study
EXPO_PUBLIC_LEGAL_LAST_UPDATED=2026-05-18

# Only when you deliberately want Expo web hitting wrangler dev (localhost Worker):
# EXPO_PUBLIC_USE_LOCAL_WEB_API=true
# EXPO_PUBLIC_API_URL=http://localhost:8787
